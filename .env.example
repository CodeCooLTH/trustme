# === Database ===
# Local (Docker): ชี้ไป postgres service
DATABASE_URL="postgresql://safepay:safepay@localhost:5432/safepay"
# Production (Supabase): pooler port 6543 + pgbouncer
# DATABASE_URL="postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL ใช้ตอน migrate เท่านั้น (port 5432 ของ Supabase)
DIRECT_URL="postgresql://safepay:safepay@localhost:5432/safepay"

# === Auth ===
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
FACEBOOK_ID=""
FACEBOOK_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# === Storage driver ===
# local = ใช้ filesystem (./uploads) — เหมาะกับ dev/docker
# s3    = ใช้ S3-compatible (Supabase Storage S3 / AWS S3 / R2 / Spaces / MinIO)
STORAGE_DRIVER="local"

# === S3-compatible storage (เมื่อ STORAGE_DRIVER=s3) ===
# Supabase:            S3_ENDPOINT=https://xxx.supabase.co/storage/v1/s3  S3_FORCE_PATH_STYLE=true
# AWS S3:              S3_ENDPOINT=""  S3_FORCE_PATH_STYLE=false
# Cloudflare R2:       S3_ENDPOINT=https://ACCOUNT.r2.cloudflarestorage.com  S3_FORCE_PATH_STYLE=true
# MinIO (local):       S3_ENDPOINT=http://localhost:9000  S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
# Public URL prefix สำหรับ object (ถ้า bucket เป็น public read)
# Supabase public: https://xxx.supabase.co/storage/v1/object/public/uploads
S3_PUBLIC_URL=""

# === URLs ===
API_URL="http://localhost:3000"
NEXT_PUBLIC_SELLER_URL="http://seller.deepth.local:4000"
